# OBS WebSocket Settings
OBS_WS_HOST=127.0.0.1
OBS_WS_PORT=4455
OBS_WS_PASSWORD=your_password_here

# OBS Stream Settings
OBS_SCENE_NAME=RADIO_TAISO_LOOP
# Name of the media source (music/video) to play on start
OBS_MEDIA_SOURCE_NAME=radio-calisthenics.wav
# Optional: OBS Profile Name
# OBS_PROFILE_NAME=

# Application Settings
LOG_DIR=./logs
START_RETRIES=3
RETRY_DELAY=5

# Path to OBS Application (on macOS)
OBS_PATH="/Applications/OBS.app/Contents/MacOS/OBS"

# Email Alert Settings (Gmail App Password expected)
ALERT_EMAIL_SENDER=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_EMAIL_RECEIVER=your_email@gmail.com

# Bird Overlay (random bird flying effect during stream)
# OBS Browser Source must be added in advance, pointing to assets/overlays/bird/index.html
OBS_BIRD_SOURCE_NAME=bird_overlay
BIRD_PROBABILITY=0.15
BIRD_INTERVAL_SEC=30
BIRD_SHOW_DURATION_SEC=7
BIRD_DURATION_SEC=960
